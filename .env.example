# --- Magazzino Solidale AIM — variabili d'ambiente ---
# Copia questo file in `.env` e compila i valori. NON committare `.env`.

# Stringa di connessione PostgreSQL (obbligatoria)
# Esempio: postgres://utente:password@localhost:5432/magazzino_solidale
DATABASE_URL=

# Segreto per la firma delle sessioni express-session (obbligatorio)
# Usa una stringa lunga e casuale, es: `openssl rand -hex 32`
SESSION_SECRET=

# Opzionali: se valorizzate, creano/aggiornano il SuperAdmin tecnico `sadmin`.
# L'email è richiesta per i nuovi utenti creati dal sistema.
SUPER_ADMIN_INITIAL_EMAIL=
SUPER_ADMIN_INITIAL_PASSWORD=

# Email transazionali SMTP.
# In development/test, se MAIL_PROVIDER resta vuoto, il servizio usa modalità log-only.
# In production impostare MAIL_PROVIDER=smtp e compilare i valori SMTP reali.
MAIL_PROVIDER=
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Magazzino Solidale <noreply@angeliinmoto.it>"
MAIL_REPLY_TO=info@angeliinmoto.it

# URL pubblico dell'app, usato per costruire link come /reset-password?token=...
APP_BASE_URL=

# Default sicuro nel codice: 60 minuti. In produzione può essere impostato a 480
# per link validi 8 ore.
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
