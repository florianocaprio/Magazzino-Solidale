# --- Magazzino Solidale AIM — variabili d'ambiente ---
# Copia questo file in `.env` e compila i valori. NON committare `.env`.

# Stringa di connessione PostgreSQL (obbligatoria)
# Esempio: postgres://utente:password@localhost:5432/magazzino_solidale
DATABASE_URL=

# Segreto per la firma delle sessioni express-session (obbligatorio)
# Usa una stringa lunga e casuale, es: `openssl rand -hex 32`
SESSION_SECRET=
